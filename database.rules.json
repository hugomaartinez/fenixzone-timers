{
  "rules": {
    "groups": {
      "$groupId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && !data.exists() && newData.child('ownerId').val() == auth.uid && newData.child('members').child(auth.uid).child('role').val() == 'owner'",
        "name": {
          ".read": "auth != null",
          ".write": "auth != null && data.parent().child('ownerId').val() == auth.uid"
        },
        "ownerId": {
          ".write": false
        },
        "createdAt": {
          ".write": false
        },
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['email', 'role', 'joinedAt']) && (newData.child('role').val() == 'member' || root.child('groups').child($groupId).child('ownerId').val() == auth.uid)"
          }
        },
        "timers": {
          ".read": "auth != null && data.parent().child('members').child(auth.uid).exists()",
          ".write": "auth != null && data.parent().child('members').child(auth.uid).exists()"
        }
      }
    },
    "userGroups": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
