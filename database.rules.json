{
  "rules": {
    "groups": {
      "$groupId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && !data.exists() && newData.child('ownerId').val() == auth.uid && newData.child('members').child(auth.uid).child('role').val() == 'owner'",
        "name": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.parent().child('ownerId').val() == auth.uid)"
        },
        "ownerId": {
          ".write": "auth != null && !data.exists() && newData.val() == auth.uid"
        },
        "createdAt": {
          ".write": "auth != null && !data.exists() && newData.isNumber()"
        },
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['email', 'role', 'joinedAt']) && (newData.child('role').val() == 'member' || (newData.child('role').val() == 'owner' && newData.parent().parent().child('ownerId').val() == auth.uid))"
          }
        },
        "timers": {
          ".read": "auth != null && data.parent().child('members').child(auth.uid).exists()",
          ".write": "auth != null && data.parent().child('members').child(auth.uid).exists()"
        },
        "transportista": {
          ".read": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
          ".write": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
          "events": {
            ".read": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
            ".write": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()"
          },
          "trips": {
            ".read": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
            ".write": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()"
          },
          "agents": {
            "$agentId": {
              ".read": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
              ".write": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()"
            }
          },
          "status": {
            ".read": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()",
            ".write": "auth != null && root.child('groups/' + $groupId + '/members/' + auth.uid).exists()"
          }
        }
      }
    },
    "userGroups": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['email', 'playerName', 'server'])"
      }
    }
  }
}
